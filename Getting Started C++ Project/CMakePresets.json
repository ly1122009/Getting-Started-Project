{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name": "gcc-dev-Debug",
      "inherits": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_FLAGS": "-Wall -Wpedantic -Wextra -Wno-unused-variable",
        "CMAKE_CXX_FLAGS": "-Wall -Wpedantic -Wextra -Wno-unused-variable"
      }
    },

    {
      "name": "gcc-dev-Release",
      "inherits": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS": "-Wall -Wpedantic -Wextra -Wno-unused-variable -O3",
        "CMAKE_CXX_FLAGS": "-Wall -Wpedantic -Wextra -Wno-unused-variable -O3"
      }
    },

    {
      "name": "gcc-dev-ASan",
      "inherits": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_FLAGS": "-Wall -Wpedantic -Wextra -Wno-unused-variable -g -O0 -fsanitize=address -fno-omit-frame-pointer",
        "CMAKE_CXX_FLAGS": "-Wall -Wpedantic -Wextra -Wno-unused-variable -g -O0 -fsanitize=address -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address"
      },
      "environment": {
        "ASAN_OPTIONS": "detect_leaks=1"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "gcc-dev-Debug",
      "configurePreset": "gcc-dev-Debug"
    },
    {
      "name": "gcc-dev-Release",
      "configurePreset": "gcc-dev-Release"
    },
    {
      "name": "gcc-dev-ASan",
      "configurePreset": "gcc-dev-ASan"
    }
  ],

  "testPresets": [
    {
      "name": "test-gcc-dev-Debug",
      "configurePreset": "gcc-dev-Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-gcc-dev-Release",
      "configurePreset": "gcc-dev-Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-gcc-dev-ASan",
      "configurePreset": "gcc-dev-ASan",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
